# Supabase — get these from your Supabase project settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Auth — generate a strong random string (e.g. openssl rand -hex 32)
JWT_SECRET=your-secret-key-minimum-32-chars

# Admin account — created automatically on first boot if no users exist
ADMIN_EMAIL=you@yourdomain.com
ADMIN_PASSWORD_HASH=your-bcrypt-hash

# Port (Railway sets this automatically — leave blank locally)
PORT=3000
